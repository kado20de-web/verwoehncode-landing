# ── wirflirten — Umgebungsvariablen ──
# Kopiere diese Datei zu ".env" und trage deine echten Werte ein.

# Öffentliche Basis-URL (für Links in E-Mails & Stripe-Redirects)
# Lokal: http://localhost:3000   ·   Live: https://wirflirten.de
BASE_URL=http://localhost:3000

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ── Resend (E-Mail-Versand) ──
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=wirflirten <noreply@wirflirten.de>

# ── Sicherheit ──
# openssl rand -hex 32
DOWNLOAD_SECRET=bitte-hier-einen-langen-zufallsstring-eintragen
DOWNLOAD_TTL_HOURS=168

# ── Admin-Bereich (/admin) ──
ADMIN_PASSWORD=bitte-ein-sicheres-passwort-setzen
ADMIN_SECRET=

# ── KI-Content-Studio (Claude / Anthropic) ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
AI_MODEL=claude-sonnet-4-6

# ── fal.ai (Bild-/Video-Generierung) ──
FAL_KEY=xxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FAL_IMAGE_MODEL=fal-ai/flux/schnell
FAL_VIDEO_MODEL=fal-ai/ltx-video

# ── Cloudinary (Medien-Hosting / CDN) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Bewertungs-Mail (14 Tage nach Kauf) ──
# Link zu deinem Google-Formular für Bewertungen
REVIEW_FORM_URL=https://forms.gle/xxxxxxxx
# Geheimer Token, um den Cron-Endpunkt /api/cron/review-emails zu schützen
# (openssl rand -hex 16)
REVIEW_CRON_TOKEN=
# Veröffentlichte CSV-URL der Antwort-Tabelle (Datei → Im Web veröffentlichen → CSV)
# Damit erscheinen echte Bewertungen automatisch auf der Landingpage.
REVIEW_SHEET_CSV_URL=

PORT=3000
